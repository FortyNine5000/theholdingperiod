---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Newsletter — The Holding Period"
			description="Subscribe to The Holding Period newsletter. Monthly institutional-grade research on long-term equity returns, delivered free."
		/>
		<style>
			.page-header {
				background: var(--bg-subtle);
				border-bottom: 1px solid var(--border);
				padding: 3.5em 1.5em 2.5em;
			}

			.page-header-inner {
				max-width: 720px;
				margin: 0 auto;
			}

			.page-eyebrow {
				font-family: var(--font-sans);
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent-muted);
				margin-bottom: 0.75em;
			}

			.page-title {
				font-family: var(--font-serif);
				font-size: 2.5em;
				font-weight: normal;
				color: var(--text);
				margin: 0 0 0.4em 0;
			}

			.page-lead {
				color: var(--text-secondary);
				font-size: 1.1em;
				line-height: 1.7;
				margin: 0;
			}

			.content {
				max-width: 720px;
				margin: 0 auto;
				padding: 3.5em 1.5em 5em;
			}

			.signup-card {
				background: var(--accent);
				border-radius: 8px;
				padding: 2.75em;
				margin-bottom: 3em;
				text-align: center;
			}

			.signup-card h2 {
				font-family: var(--font-serif);
				font-size: 1.8em;
				font-weight: normal;
				color: white;
				margin: 0 0 0.5em 0;
			}

			.signup-card p {
				color: rgba(255,255,255,0.82);
				font-size: 1.02em;
				margin-bottom: 2em;
				line-height: 1.6;
			}

			.signup-form {
				display: flex;
				gap: 0.75em;
				max-width: 420px;
				margin: 0 auto;
			}

			.signup-form input[type="email"] {
				flex: 1;
				padding: 0.8em 1em;
				border: 1.5px solid rgba(255,255,255,0.3);
				border-radius: 4px;
				background: rgba(255,255,255,0.1);
				color: white;
				font-size: 0.95em;
				outline: none;
				transition: border-color 0.15s ease;
			}

			.signup-form input[type="email"]::placeholder {
				color: rgba(255,255,255,0.55);
			}

			.signup-form input[type="email"]:focus {
				border-color: rgba(255,255,255,0.6);
				background: rgba(255,255,255,0.15);
			}

			.signup-form button {
				padding: 0.8em 1.5em;
				background: white;
				color: var(--accent);
				border: none;
				border-radius: 4px;
				font-family: var(--font-sans);
				font-weight: 700;
				font-size: 0.9em;
				cursor: pointer;
				white-space: nowrap;
				transition: opacity 0.15s ease;
			}

			.signup-form button:hover {
				opacity: 0.9;
			}

			.signup-note {
				margin-top: 1em;
				font-size: 0.82em;
				color: rgba(255,255,255,0.55);
			}

			.what-you-get h3 {
				font-family: var(--font-serif);
				font-size: 1.5em;
				font-weight: normal;
				color: var(--text);
				margin: 0 0 1.25em 0;
			}

			.benefit-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1em;
			}

			.benefit-item {
				display: flex;
				align-items: flex-start;
				gap: 1em;
				padding: 1.25em;
				background: var(--bg-subtle);
				border: 1px solid var(--border);
				border-radius: 6px;
			}

			.benefit-icon {
				font-size: 1.4em;
				line-height: 1;
				min-width: 1.5em;
				text-align: center;
				padding-top: 0.1em;
			}

			.benefit-text strong {
				display: block;
				font-family: var(--font-sans);
				font-weight: 700;
				font-size: 0.92em;
				color: var(--text);
				margin-bottom: 0.2em;
			}

			.benefit-text span {
				font-size: 0.9em;
				color: var(--text-secondary);
				line-height: 1.5;
			}

			.frequency-note {
				margin-top: 2em;
				padding: 1.25em 1.5em;
				background: var(--bg-accent);
				border: 1px solid var(--border);
				border-radius: 6px;
				font-size: 0.9em;
				color: var(--text-secondary);
				line-height: 1.6;
			}

			.frequency-note strong {
				color: var(--text);
			}

			@media (max-width: 720px) {
				.page-title { font-size: 1.8em; }
				.page-header { padding: 2em 1em 1.5em; }
				.content { padding: 2em 1em 3em; }
				.signup-card { padding: 2em 1.25em; }
				.signup-form { flex-direction: column; }
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="page-header">
			<div class="page-header-inner">
				<p class="page-eyebrow">Monthly Research Digest</p>
				<h1 class="page-title">The Newsletter</h1>
				<p class="page-lead">
					Rigorous long-term market research, delivered monthly. No market timing. No noise. Just the long view.
				</p>
			</div>
		</div>

		<div class="content">
			<div class="signup-card">
				<h2>Think in Decades</h2>
				<p>
					Join investors who understand that the most powerful edge in markets is simply a longer time horizon than everyone else.
				</p>
				<form class="signup-form" action="#" method="post">
					<input type="email" name="email" placeholder="your@email.com" required />
					<button type="submit">Subscribe</button>
				</form>
				<p class="signup-note">Free. No spam. Unsubscribe anytime.</p>
			</div>

			<div class="what-you-get">
				<h3>What You'll Receive</h3>
				<ul class="benefit-list">
					<li class="benefit-item">
						<div class="benefit-icon">&#x1F4C8;</div>
						<div class="benefit-text">
							<strong>Monthly Research Essays</strong>
							<span>One substantial, data-driven piece each month on a topic in long-term market history, valuation, or return dynamics.</span>
						</div>
					</li>
					<li class="benefit-item">
						<div class="benefit-icon">&#x1F4CA;</div>
						<div class="benefit-text">
							<strong>Data Updates</strong>
							<span>Quarterly updates to key long-term metrics: the Shiller CAPE, rolling return tables, and dividend yield history.</span>
						</div>
					</li>
					<li class="benefit-item">
						<div class="benefit-icon">&#x1F4DA;</div>
						<div class="benefit-text">
							<strong>Reading Recommendations</strong>
							<span>Curated links to the best academic papers, books, and long-form writing on empirical finance and investment history.</span>
						</div>
					</li>
					<li class="benefit-item">
						<div class="benefit-icon">&#x1F914;</div>
						<div class="benefit-text">
							<strong>Historical Perspective</strong>
							<span>Context that only comes from studying a century of market data — helping you stay grounded when short-term volatility creates anxiety.</span>
						</div>
					</li>
				</ul>

				<div class="frequency-note">
					<strong>Cadence:</strong> Monthly, typically in the first week of the month. Occasional special issues when market conditions warrant historical perspective. We will never send more than twice per month.
				</div>
			</div>
		</div>
		<Footer />
	</body>
</html>
