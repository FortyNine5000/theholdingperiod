---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Research — The Holding Period"
			description="Long-term equity market research and analysis from The Holding Period. Institutional-grade insights on multi-decade investment returns."
		/>
		<style>
			.page-header {
				background: var(--bg-subtle);
				border-bottom: 1px solid var(--border);
				padding: 3.5em 1.5em 2.5em;
			}

			.page-header-inner {
				max-width: 1100px;
				margin: 0 auto;
			}

			.page-eyebrow {
				font-family: var(--font-sans);
				font-size: 0.75em;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent-muted);
				margin-bottom: 0.75em;
			}

			.page-title {
				font-family: var(--font-serif);
				font-size: 2.5em;
				font-weight: normal;
				color: var(--text);
				margin: 0 0 0.4em 0;
			}

			.page-desc {
				color: var(--text-secondary);
				font-size: 1.05em;
				max-width: 580px;
				margin: 0;
			}

			.content {
				max-width: 1100px;
				margin: 0 auto;
				padding: 3em 1.5em 5em;
			}

			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0;
			}

			.post-item {
				border-bottom: 1px solid var(--border);
			}

			.post-item:first-child {
				border-top: 1px solid var(--border);
			}

			.post-link {
				display: grid;
				grid-template-columns: 140px 1fr auto;
				align-items: baseline;
				gap: 1.5em;
				padding: 1.5em 0;
				text-decoration: none;
				transition: all 0.15s ease;
			}

			.post-link:hover {
				text-decoration: none;
			}

			.post-link:hover .post-title {
				color: var(--accent);
			}

			.post-date {
				font-family: var(--font-sans);
				font-size: 0.82em;
				color: var(--text-muted);
				white-space: nowrap;
				padding-top: 0.25em;
			}

			.post-content {
				flex: 1;
			}

			.post-title {
				font-family: var(--font-serif);
				font-size: 1.25em;
				font-weight: normal;
				color: var(--text);
				margin: 0 0 0.35em 0;
				line-height: 1.3;
				transition: color 0.15s ease;
			}

			.post-desc {
				font-size: 0.9em;
				color: var(--text-secondary);
				line-height: 1.55;
				margin: 0;
			}

			.post-arrow {
				font-size: 1.1em;
				color: var(--text-muted);
				transition: transform 0.15s ease, color 0.15s ease;
			}

			.post-link:hover .post-arrow {
				transform: translateX(3px);
				color: var(--accent);
			}

			@media (max-width: 640px) {
				.page-title { font-size: 1.8em; }
				.page-header { padding: 2em 1em 1.5em; }
				.content { padding: 2em 1em 3em; }

				.post-link {
					grid-template-columns: 1fr;
					gap: 0.4em;
					padding: 1.25em 0;
				}

				.post-arrow { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="page-header">
			<div class="page-header-inner">
				<p class="page-eyebrow">Long-Term Market Research</p>
				<h1 class="page-title">Research</h1>
				<p class="page-desc">
					Rigorous, data-driven analysis on equity market history, valuation, and long-term return dynamics.
				</p>
			</div>
		</div>

		<div class="content">
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-item">
						<a href={`/research/${post.id}/`} class="post-link">
							<div class="post-date">
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class="post-content">
								<h2 class="post-title">{post.data.title}</h2>
								<p class="post-desc">{post.data.description}</p>
							</div>
							<span class="post-arrow">&rarr;</span>
						</a>
					</li>
				))}
			</ul>
		</div>
		<Footer />
	</body>
</html>
