---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<div class="footer-wordmark">The Holding Period</div>
			<p class="footer-tagline">
				Institutional-grade research on very long-term equity returns. For investors who measure success in decades.
			</p>
		</div>
		<div class="footer-links">
			<div class="footer-col">
				<div class="footer-col-title">Explore</div>
				<a href="/research">Research</a>
				<a href="/data">Data</a>
				<a href="/newsletter">Newsletter</a>
				<a href="/about">About</a>
			</div>
			<div class="footer-col">
				<div class="footer-col-title">Resources</div>
				<a href="/rss.xml">RSS Feed</a>
			</div>
		</div>
	</div>
	<div class="footer-bottom">
		<span>&copy; {today.getFullYear()} The Holding Period. All rights reserved.</span>
		<span class="footer-disclaimer">For educational purposes only. Not investment advice.</span>
	</div>
</footer>

<style>
	footer {
		background: var(--bg-subtle);
		border-top: 1px solid var(--border);
		margin-top: 5em;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3.5em 1.5em 2.5em;
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 4em;
	}

	.footer-wordmark {
		font-family: var(--font-sans);
		font-size: 0.82em;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 0.75em;
	}

	.footer-tagline {
		font-size: 0.9em;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 340px;
		margin: 0;
	}

	.footer-links {
		display: flex;
		gap: 4em;
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}

	.footer-col-title {
		font-family: var(--font-sans);
		font-size: 0.75em;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 0.4em;
	}

	.footer-col a {
		font-size: 0.9em;
		color: var(--text-secondary);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.footer-col a:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.footer-bottom {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25em 1.5em;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1em;
		font-size: 0.82em;
		color: var(--text-muted);
	}

	.footer-disclaimer {
		font-style: italic;
	}

	@media (max-width: 768px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 2em;
			padding: 2.5em 1em 1.5em;
		}

		.footer-links {
			gap: 2em;
		}

		.footer-bottom {
			flex-direction: column;
			text-align: center;
			gap: 0.5em;
			padding: 1em;
		}
	}
</style>
