---
// No server-side props needed
---

<section class="newsletter-section">
  <div class="newsletter-inner">
    <div class="newsletter-copy">
      <h2 class="newsletter-headline">The pick is public. The runners-up aren't.</h2>
      <p class="newsletter-sub">
        Each quarter, I publish my short list — the four stocks that almost made the cut —
        exclusively to subscribers.
      </p>
    </div>

    <form class="newsletter-form" id="newsletter-form" novalidate>
      <!-- Honeypot: do not show to users -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        style="display:none;"
      />

      <div class="form-row">
        <input
          type="text"
          name="name"
          id="nl-name"
          placeholder="Your name"
          autocomplete="given-name"
          required
        />
        <input
          type="email"
          name="email"
          id="nl-email"
          placeholder="Your email"
          autocomplete="email"
          required
        />
        <button type="submit" class="cta-btn">Get the short list</button>
      </div>

      <p class="form-message" id="nl-message" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
  const msg = document.getElementById("nl-message");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !msg) return;

    const data = new FormData(form);
    const payload = {
      name: (data.get("name") as string ?? "").trim(),
      email: (data.get("email") as string ?? "").trim(),
      // honeypot
      website: (data.get("website") as string ?? "").trim(),
    };

    if (!payload.email) {
      msg.textContent = "Please enter your email address.";
      return;
    }

    const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;
    msg.textContent = "Submitting…";

    try {
      const res = await fetch("/api/newsletter", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });

      if (res.ok) {
        msg.textContent = "You're in. Expect the short list next quarter.";
        form.reset();
      } else {
        msg.textContent = "Something went wrong. Please try again.";
      }
    } catch {
      msg.textContent = "Network error. Please try again.";
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  .newsletter-section {
    margin-top: 3rem;
    padding: 2rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
  }
  .newsletter-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .newsletter-headline {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }
  .newsletter-sub {
    margin: 0.375rem 0 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
  }
  .newsletter-form {
    width: 100%;
  }
  .form-row {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .form-row input[type="text"],
  .form-row input[type="email"] {
    flex: 1;
    min-width: 160px;
    padding: 0.6rem 0.875rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text);
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .form-row input:focus {
    border-color: var(--accent);
  }
  .cta-btn {
    padding: 0.6rem 1.25rem;
    background: var(--accent);
    color: #000;
    font-weight: 600;
    font-size: 0.9rem;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .cta-btn:hover {
    opacity: 0.9;
  }
  .cta-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .form-message {
    margin: 0.5rem 0 0;
    font-size: 0.8125rem;
    color: var(--text-muted);
    min-height: 1.2em;
  }
</style>
