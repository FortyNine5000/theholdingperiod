---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<div class="header-inner">
		<a href="/" class="wordmark">
			<span class="wordmark-main">{SITE_TITLE}</span>
		</a>
		<nav>
			<HeaderLink href="/research">Research</HeaderLink>
			<HeaderLink href="/data">Data</HeaderLink>
			<HeaderLink href="/newsletter">Newsletter</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</nav>
	</div>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.97);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid var(--border);
	}

	.header-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 1.5em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}

	.wordmark {
		text-decoration: none;
	}

	.wordmark-main {
		font-family: var(--font-sans);
		font-size: 0.82em;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
		display: block;
	}

	nav {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	nav :global(a) {
		font-family: var(--font-sans);
		font-size: 0.88em;
		font-weight: 500;
		color: var(--text-secondary);
		padding: 0.5em 0.85em;
		border-radius: 4px;
		text-decoration: none;
		transition: color 0.15s ease, background 0.15s ease;
		letter-spacing: 0.01em;
	}

	nav :global(a:hover) {
		color: var(--accent);
		background: var(--bg-accent);
		text-decoration: none;
	}

	nav :global(a.active) {
		color: var(--accent);
		font-weight: 600;
	}

	@media (max-width: 640px) {
		.header-inner {
			padding: 0 1em;
			height: 56px;
		}

		nav :global(a) {
			font-size: 0.82em;
			padding: 0.4em 0.6em;
		}
	}
</style>
