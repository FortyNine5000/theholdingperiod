---
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === "/") return currentPath === "/";
  return currentPath.startsWith(path);
}
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="site-name">The Holding Period</a>
    <nav aria-label="Main navigation">
      <ul>
        <li>
          <a href="/" class:list={["nav-link", { active: isActive("/") && !isActive("/picks") && !isActive("/about") && !isActive("/contact") }]}>
            Dashboard
          </a>
        </li>
        <li>
          <a href="/about" class:list={["nav-link", { active: isActive("/about") }]}>
            About
          </a>
        </li>
        <li>
          <a href="/contact" class:list={["nav-link", { active: isActive("/contact") }]}>
            Contact
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    padding: 0 var(--page-pad);
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    gap: 1rem;
  }
  .site-name {
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }
  .site-name:hover {
    color: var(--accent);
  }
  nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
  }
  .nav-link {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }
  .nav-link.active {
    font-weight: 500;
  }
</style>
